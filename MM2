-- Helper functions (unchanged)
local function getRoleColor(role)
    if role == "Murderer" then return Color3.fromRGB(255, 100, 100)
    elseif role == "Sheriff" then return Color3.fromRGB(100, 150, 255)
    else return Color3.fromRGB(100, 255, 100) end
end

local function getRole(player)
    if player == LP then return "You" end
    local char = player.Character
    if char then
        for _, tool in pairs(char:GetChildren()) do
            if tool:IsA("Tool") then
                local name = tool.Name:lower()
                if name:find("knife") or name:find("murderer") then return "Murderer"
                elseif name:find("gun") or name:find("sheriff") then return "Sheriff" end
            end
        end
    end
    for _, tool in pairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local name = tool.Name:lower()
            if name:find("knife") or name:find("murderer") then return "Murderer"
            elseif name:find("gun") or name:find("sheriff") then return "Sheriff" end
        end
    end
    return "Innocent"
end

local function hasKnife(player)
    local char = player.Character
    if not char then return false end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower():find("knife") or tool.Name:lower():find("murderer")) then
            return true
        end
    end
    return false
end

local function hasGun(player)
    local char = player.Character
    if not char then return false end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower():find("gun") or tool.Name:lower():find("sheriff")) then
            return true
        end
    end
    return false
end

-- Auto Farm
local function autoFarm()
    if not Settings.AutoFarm then
        if autoFarmConnection then autoFarmConnection:Disconnect() end
        return
    end
    if autoFarmConnection then autoFarmConnection:Disconnect() end
    autoFarmConnection = RunService.RenderStepped:Connect(function()
        local char = LP.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local nearestItem = nil
        local nearestDist = 10
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name:lower():find("coin") or obj.Name:lower():find("money") or obj.Name:lower():find("drop") or obj:FindFirstChild("TouchInterest")) then
                local dist = (hrp.Position - obj.Position).Magnitude
                if dist < nearestDist and dist < 8 then
                    nearestDist = dist
                    nearestItem = obj
                end
            end
        end
        if nearestItem then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then
                humanoid:MoveTo(nearestItem.Position)
            end
        end
    end)
end

-- ESP (name, hitbox, tracer, tool icons)
local function updateESP()
    if not Settings.ESP then
        for _, v in pairs(espObjects) do
            if v.label then v.label:Destroy() end
            if v.box then v.box:Destroy() end
            if v.tracer then v.tracer:Destroy() end
            if v.toolIcon then v.toolIcon:Destroy() end
        end
        espObjects = {}
        return
    end
    
    local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = plr.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local role = getRole(plr)
            local col = getRoleColor(role)
            local dist = (LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") and 
                         (hrp.Position - LP.Character.HumanoidRootPart.Position).Magnitude or 0)
            local text = string.format("%s [%s] %.0fm", plr.Name, role, dist)
            
            if not espObjects[plr] then
                local label = Instance.new("TextLabel")
                label.BackgroundTransparency = 1
                label.TextStrokeTransparency = 0.3
                label.TextColor3 = col
                label.Font = Enum.Font.GothamBold
                label.TextSize = 14
                label.Parent = screenGui
                local box = nil
                if Settings.Hitbox then
                    box = Instance.new("Frame")
                    box.BackgroundTransparency = 0.6
                    box.BorderSizePixel = 2
                    box.BorderColor3 = col
                    box.BackgroundColor3 = col
                    box.Size = UDim2.new(0, 60, 0, 80)
                    box.Parent = screenGui
                end
                local tracer = nil
                if Settings.Tracers then
                    tracer = Instance.new("Frame")
                    tracer.BackgroundColor3 = col
                    tracer.BorderSizePixel = 0
                    tracer.BackgroundTransparency = 0.4
                    tracer.Parent = screenGui
                end
                local toolIcon = nil
                if Settings.ShowMurdererTools then
                    toolIcon = Instance.new("TextLabel")
                    toolIcon.BackgroundTransparency = 1
                    toolIcon.Text = ""
                    toolIcon.Font = Enum.Font.GothamBold
                    toolIcon.TextSize = 24
                    toolIcon.Parent = screenGui
                end
                espObjects[plr] = {label = label, box = box, tracer = tracer, toolIcon = toolIcon}
            end
            
            local data = espObjects[plr]
            data.label.TextColor3 = col
            if data.box then data.box.BorderColor3 = col end
            if data.tracer then data.tracer.BackgroundColor3 = col end
            if data.toolIcon then
                if hasKnife(plr) then data.toolIcon.Text = "🔪"
                elseif hasGun(plr) then data.toolIcon.Text = "🔫"
                else data.toolIcon.Text = "" end
                data.toolIcon.TextColor3 = col
            end
            
            if onScreen then
                data.label.Text = text
                data.label.Position = UDim2.new(0, pos.X - 100, 0, pos.Y - 30)
                data.label.Size = UDim2.new(0, 200, 0, 22)
                data.label.Visible = true
                
                if Settings.Hitbox and data.box then
                    local sizeOnScreen = 100 / (pos.Z or 1)
                    data.box.Size = UDim2.new(0, sizeOnScreen, 0, sizeOnScreen * 1.5)
                    data.box.Position = UDim2.new(0, pos.X - sizeOnScreen/2, 0, pos.Y - sizeOnScreen*0.75)
                    data.box.Visible = true
                elseif data.box then data.box.Visible = false end
                
                if Settings.Tracers and data.tracer then
                    local startPos = centerScreen
                    local endPos = Vector2.new(pos.X, pos.Y)
                    local length = (endPos - startPos).Magnitude
                    local angle = math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X)
                    data.tracer.Position = UDim2.new(0, startPos.X, 0, startPos.Y)
                    data.tracer.Size = UDim2.new(0, length, 0, 3)
                    data.tracer.Rotation = math.deg(angle)
                    data.tracer.Visible = true
                elseif data.tracer then data.tracer.Visible = false end
                
                if Settings.ShowMurdererTools and data.toolIcon and data.toolIcon.Text ~= "" then
                    data.toolIcon.Position = UDim2.new(0, pos.X - 20, 0, pos.Y - 60)
                    data.toolIcon.Size = UDim2.new(0, 40, 0, 40)
                    data.toolIcon.Visible = true
                elseif data.toolIcon then data.toolIcon.Visible = false end
            else
                data.label.Visible = false
                if data.box then data.box.Visible = false end
                if data.tracer then data.tracer.Visible = false end
                if data.toolIcon then data.toolIcon.Visible = false end
            end
        elseif espObjects[plr] then
            local data = espObjects[plr]
            data.label.Visible = false
            if data.box then data.box.Visible = false end
            if data.tracer then data.tracer.Visible = false end
            if data.toolIcon then data.toolIcon.Visible = false end
        end
    end
    
    for plr, data in pairs(espObjects) do
        if not plr or not plr.Parent then
            data.label:Destroy()
            if data.box then data.box:Destroy() end
            if data.tracer then data.tracer:Destroy() end
            if data.toolIcon then data.toolIcon:Destroy() end
            espObjects[plr] = nil
        end
    end
end

-- Knife throw
local function throwKnifeAt(targetPos)
    local char = LP.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then tool:Activate() end
end

local function autoKnifeThrowLoop()
    if not Settings.AutoKnifeThrow then return end
    local char = LP.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LP and getRole(plr) ~= "Murderer" then
            local targetPart = plr.Character and (plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("HumanoidRootPart"))
            if targetPart then
                throwKnifeAt(targetPart.Position)
                task.wait(0.2)
            end
        end
    end
end

-- Hostage mode
local function setHostageMode()
    if hostageConnection then hostageConnection:Disconnect() end
    if not Settings.HostageMode then return end
    hostageConnection = RunService.Stepped:Connect(function()
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character then
                local humanoid = plr.Character:FindFirstChild("Humanoid")
                if humanoid then
                    humanoid.WalkSpeed = 0
                    humanoid.JumpPower = 0
                end
            end
        end
    end)
end

-- Sheriff shoot
local function shootAt(targetPos)
    local char = LP.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then tool:Activate() end
end

local function autoShootLoop()
    if not Settings.AutoShoot then return end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LP and plr.Character and getRole(plr) == "Murderer" then
            local targetPart = plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("HumanoidRootPart")
            if targetPart then
                shootAt(targetPart.Position)
                task.wait(0.2)
            end
        end
    end
end

-- Auto pickup gun
local function getDroppedGun()
    local char = LP.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Tool") and (obj.Name:lower():find("gun") or obj.Name:lower():find("sheriff")) then
            if (hrp.Position - obj.Parent.Position).Magnitude < 5 then
                obj.Parent = char
                break
            end
        end
    end
end

local function autoPickupLoop()
    if Settings.AutoPickupGun then
        getDroppedGun()
        task.wait(0.5)
    end
end

-- Fling
local function flingPlayer(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if targetHRP then
        targetHRP.Velocity = Vector3.new(math.random(-100,100), math.random(50,150), math.random(-100,100))
    end
end

local function flingLoop()
    if Settings.FlingSheriff then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LP and getRole(plr) == "Sheriff" then flingPlayer(plr) end
        end
    end
    if Settings.FlingMurderer then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LP and getRole(plr) == "Murderer" then flingPlayer(plr) end
        end
    end
end

-- Anti fling
local function antiFling()
    if not Settings.AntiFling then
        if antiFlingConn then antiFlingConn:Disconnect() end
        return
    end
    if antiFlingConn then antiFlingConn:Disconnect() end
    antiFlingConn = RunService.Stepped:Connect(function()
        local char = LP.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp and hrp.Velocity.Magnitude > 100 then
                hrp.Velocity = Vector3.new(0,0,0)
            end
        end
    end)
end

-- Movement & FOV
local function applyMovement()
    local char = LP.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = Settings.Speed
            humanoid.JumpPower = Settings.JumpPower
        end
    end
end

local function setFOV()
    Camera.FieldOfView = Settings.FOV
end

-- Noclip
local function toggleNoclip()
    if Settings.NoClip then
        if noclipConn then noclipConn:Disconnect() end
        noclipConn = RunService.Stepped:Connect(function()
            local char = LP.Character
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end)
    else
        if noclipConn then noclipConn:Disconnect() end
        local char = LP.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
        end
    end
end

